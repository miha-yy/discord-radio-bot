{
  "name": "discord-radio-bot",
  "version": "1.0.0",
  "description": "Discord bot that joins voice and plays live radio from a configurable list of stations (many genres and regions)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js"
  },
  "keywords": ["discord", "radio", "bot", "voice", "stations", "stream"],
  "license": "MIT",
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "@snazzah/davey": "^0.1.6",
    "@noble/ciphers": "^1.0.3",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.2.0",
    "prism-media": "^1.3.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
